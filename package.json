{
  "name": "traduzco",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter @traduzco/web dev",
    "dev:torre": "pnpm --filter @traduzco/mata-el-torre dev",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "build:site": "pnpm -r build && rm -rf site && mkdir -p site/mata-el-torre && cp -r apps/web/dist/. site/ && cp -r apps/mata-el-torre/dist/. site/mata-el-torre/"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "wrangler": "4.107.0"
  }
}
